# ─────────────────────────────────────────────────────────────
# Configuración de impresión para Docker Compose
# ─────────────────────────────────────────────────────────────
# Copiar este archivo como .env y ajustar los valores
#
# Para encontrar la IP de tu Canon TS8300:
#   1. En la impresora: Configuración → Red → WiFi → Ver info
#   2. O ejecutar: docker compose up -d && curl http://localhost:8001/printers
#   3. O desde Windows: abrir cmd y ejecutar: arp -a | findstr "Canon"
#
# ─────────────────────────────────────────────────────────────

# Backend de impresión:
#   auto  = detecta automáticamente (CUPS si disponible, sino IPP)
#   ipp   = IPP directo (para Windows/impresoras en red)
#   cups  = CUPS (solo Linux)
PRINTER_BACKEND=ipp

# Impresora 1 (sellos motivo izquierdo)
# Formato: IP de la impresora o URL IPP completa
# Ejemplos:
#   192.168.1.50
#   ipp://192.168.1.50:631/ipp/print
#   canon-ts8300.local
PRINTER_1=192.168.1.50

# Impresora 2 (sellos motivo derecho)
# Si usas la misma impresora para todo, pon la misma IP
PRINTER_2=192.168.1.50

# Impresora de tickets
PRINTER_TICKET=192.168.1.50
