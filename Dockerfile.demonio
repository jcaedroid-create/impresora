# Python 3.10 para el servidor WebSocket del demonio
FROM python:3.10-slim-bookworm

# Instalar CUPS client para poder usar lp, cupsenable, cupsdisable
RUN apt-get update && \
    apt-get install -y --no-install-recommends cups-client && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copiar los scripts Python y recursos
COPY demonio/ /app/

# Instalar dependencias Python
RUN pip install --no-cache-dir SimpleWebSocketServer reportlab

EXPOSE 8000 8001

CMD ["python", "-u", "servidor-ws.py"]
